    <worksheet name='Gantt Chart'>
      <layout-options>
        <title>
          <formatted-text>
            <run fontalignment='1'>Gantt Chart</run>
          </formatted-text>
        </title>
      </layout-options>
      <table>
        <view>
          <datasources>
            <datasource caption='Orders+ (Super Store)' name='federated.0gz38hk0etwfdf15lqesn109ua3u' />
          </datasources>
          <datasource-dependencies datasource='federated.0gz38hk0etwfdf15lqesn109ua3u'>
            <column caption='OrderUntilShip' datatype='integer' name='[Calculation_0831023029432320]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='DATEDIFF(&apos;day&apos;,[Order Date],[Ship Date])' />
